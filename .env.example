# Atlas Kings — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── API-Football-DATA ──────────────────────────────
# Get your key at: https://dashboard.api-football.com
# Free plan: 100 requests/day
# Pro plan: 7,500 requests/day ($19/month)
APIFOOTBALL_KEY=your_apifootball_key_here
# Same key, exposed client-side for API-Football widgets
NEXT_PUBLIC_APIFOOTBALL_KEY=your_apifootball_key_here


# ── Site URL ──────────────────────────────────
# Used for SEO, OG images, sitemaps
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Analytics (optional) ──────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

PIPELINE_SECRET=atlas2026

# ── Youtube ────────────────────────────
YOUTUBE_API_KEY=AIzaSyB4d9O-oaPLvP8_DInfvcKLzFzGq0gZxaQ

# ── Push Notifications ─────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
# Then install: npm install web-push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:editorial@atlaskings.com

# Secret to protect the /api/push/send endpoint
PUSH_SECRET=your_random_secret_here

# ── Anthropic API (for AI article rewriting) ──────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database (Neon PostgreSQL) ─────────────────────
# Get your connection string at: https://console.neon.tech/
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Article Pipeline ──────────────────────────────
# Secret to protect /api/pipeline endpoint
PIPELINE_SECRET=your_pipeline_secret_here


# ── Cloudflare R2 (article image storage) ────────
# Create an R2 bucket and API token at: https://dash.cloudflare.com/
CLOUDFLARE_R2_BUCKET_NAME=your_r2_bucket_name
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_PUBLIC_URL=https://your-r2-public-url.r2.dev
CLOUDFLARE_R2_ACCOUNT_ID=your_r2_account_id

# ── Sentry (optional — error tracking) ──────────────
# Leave DSN empty to disable Sentry entirely (no-op SDK init).
# Create a project at https://sentry.io/ then paste the DSN here.
NEXT_PUBLIC_SENTRY_DSN=
# Server-only: needed by `withSentryConfig` to upload source maps
# during CI/production builds. Safe to leave empty in dev.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=